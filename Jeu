// ========== VOICE RECORD ==========
let mediaRec=null, recChunks=[], recStart=null, recInterval=null;
function recStart(e){ e.preventDefault(); if(mediaRec) return;
  navigator.mediaDevices.getUserMedia({audio:true}).then(stream=>{
    recChunks=[];
    mediaRec=new MediaRecorder(stream);
    mediaRec.ondataavailable=ev=>{ if(ev.data.size>0) recChunks.push(ev.data); };
    mediaRec.onstop=()=>{
      stream.getTracks().forEach(t=>t.stop());
      const dur=(Date.now()-recStart)/1000;
      if(dur<0.5){ mediaRec=null; return; }
      const blob=new Blob(recChunks,{type:'audio/webm'});
      const r=new FileReader();
      r.onload=ev=>{
        S.messages.push({id:Date.now().toString(),timestamp:Date.now(),author:currentUser,voice:ev.target.result,voiceDuration:Math.round(dur)});
        if(S.messages.length>80) S.messages.shift();
        sync();
      };
      r.readAsDataURL(blob);
      mediaRec=null;
    };
    mediaRec.start(); recStart=Date.now();
    document.getElementById('recbtn').classList.add('rec');
    document.getElementById('rectimer').style.display='block';
    let s=0; document.getElementById('recsec').textContent=s;
    recInterval=setInterval(()=>{ s++; document.getElementById('recsec').textContent=s; if(s>=60) recStop(); },1000);
  }).catch(()=>alert('Microphone non disponible'));
}
function recStop(e){ if(e) e.preventDefault(); if(!mediaRec) return;
  clearInterval(recInterval);
  document.getElementById('recbtn').classList.remove('rec');
  document.getElementById('rectimer').style.display='none';
  mediaRec.stop();
}

// ========== VIDEO CALL (WebRTC + Firestore signaling) ==========
let pc=null, localStream=null, callUnsubscribe=null, isCaller=false, mutedAudio=false, mutedCam=false;
const iceConfig={iceServers:[{urls:'stun:stun.l.google.com:19302'},{urls:'stun:stun1.l.google.com:19302'}]};

async function startCall(){
  if(!currentUser) return;
  isCaller=true;
  document.getElementById('call-status').textContent='📞 Appel en cours...';
  document.getElementById('call-modal').style.display='flex';
  await setupLocalStream();
  pc=new RTCPeerConnection(iceConfig);
  localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
  pc.ontrack=e=>{ document.getElementById('remote-video').srcObject=e.streams[0]; document.getElementById('call-status').textContent='🟢 Connecté'; };
  pc.onicecandidate=e=>{ if(e.candidate) callRef.collection('callerCandidates').add(e.candidate.toJSON()); };

  const offer=await pc.createOffer();
  await pc.setLocalDescription(offer);
  await callRef.set({offer:{type:offer.type,sdp:offer.sdp},caller:currentUser,status:'ringing',answer:null});

  // Listen for answer
  callUnsubscribe=callRef.onSnapshot(async snap=>{
    const d=snap.data();
    if(!d) return;
    if(d.answer && pc && !pc.currentRemoteDescription){
      await pc.setRemoteDescription(new RTCSessionDescription(d.answer));
    }
    if(d.status==='ended') endCall();
  });
  // Caller listens for callee ICE
  callRef.collection('calleeCandidates').onSnapshot(snap=>{
    snap.docChanges().forEach(async ch=>{ if(ch.type==='added'&&pc){ await pc.addIceCandidate(new RTCIceCandidate(ch.doc.data())); } });
  });
}

async function setupLocalStream(){
  try {
    localStream=await navigator.mediaDevices.getUserMedia({video:true,audio:true});
    document.getElementById('local-video').srcObject=localStream;
  } catch(e){
    try {
      localStream=await navigator.mediaDevices.getUserMedia({audio:true});
    } catch(e2){ alert('Impossible d\'accéder à la caméra/micro'); }
  }
}

// Watch for incoming calls
callRef.onSnapshot(async snap=>{
  const d=snap.data();
  if(!d||!currentUser||isCaller) return;
  if(d.status==='ringing'&&d.caller!==currentUser&&!document.getElementById('call-modal').style.display.includes('flex')){
    document.getElementById('inc-caller').textContent=d.caller+' vous appelle...';
    document.getElementById('incoming-call').classList.add('show');
  }
  if(d.status==='ended'&&!isCaller) endCall();
});

async function answerCall(){
  document.getElementById('incoming-call').classList.remove('show');
  isCaller=false;
  document.getElementById('call-status').textContent='Connexion...';
  document.getElementById('call-modal').style.display='flex';
  await setupLocalStream();
  pc=new RTCPeerConnection(iceConfig);
  localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
  pc.ontrack=e=>{ document.getElementById('remote-video').srcObject=e.streams[0]; document.getElementById('call-status').textContent='🟢 Connecté'; };
  pc.onicecandidate=e=>{ if(e.candidate) callRef.collection('calleeCandidates').add(e.candidate.toJSON()); };

  const snap=await callRef.get();
  const d=snap.data();
  await pc.setRemoteDescription(new RTCSessionDescription(d.offer));
  const answer=await pc.createAnswer();
  await pc.setLocalDescription(answer);
  await callRef.update({answer:{type:answer.type,sdp:answer.sdp},status:'connected'});

  callRef.collection('callerCandidates').onSnapshot(snap2=>{
    snap2.docChanges().forEach(async ch=>{ if(ch.type==='added'&&pc){ await pc.addIceCandidate(new RTCIceCandidate(ch.doc.data())); } });
  });
}

function rejectCall(){
  document.getElementById('incoming-call').classList.remove('show');
  callRef.update({status:'ended'}).catch(()=>{});
}

function endCall(){
  document.getElementById('call-modal').style.display='none';
  document.getElementById('incoming-call').classList.remove('show');
  if(localStream){ localStream.getTracks().forEach(t=>t.stop()); localStream=null; }
  if(pc){ pc.close(); pc=null; }
  if(callUnsubscribe){ callUnsubscribe(); callUnsubscribe=null; }
  isCaller=false; mutedAudio=false; mutedCam=false;
  callRef.update({status:'ended'}).catch(()=>{});
  // Clean candidates
  ['callerCandidates','calleeCandidates'].forEach(col=>{
    callRef.collection(col).get().then(s=>s.forEach(d=>d.ref.delete())).catch(()=>{});
  });
}

