<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Espace Privé ❤️</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');
:root {
  --grad: linear-gradient(to bottom,#10121e,#3a2533,#57333a,#1f1b24);
  --mine: #005c4b; --other: #202329; --fg: #f1f1f1; --sub: #8c8c93;
  --acc: #00a884; --tc: #a0a0a5;
}
body.love { --grad: linear-gradient(to bottom,#1a030b,#4a0d25,#8b023f,#1f040c); --mine:#8b023f; --acc:#ff477e; }
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;}
body{background:var(--grad);color:var(--fg);height:100vh;display:flex;flex-direction:column;overflow:hidden;}

/* TOAST */
#toast{position:fixed;top:-110px;left:5%;width:90%;background:#202329;border-radius:15px;padding:14px 16px;display:flex;align-items:center;gap:14px;box-shadow:0 10px 30px rgba(0,0,0,.5);z-index:900;transition:top .4s cubic-bezier(.175,.885,.32,1.275);border-left:5px solid var(--acc);cursor:pointer;}
.t-ico{font-size:1.8em;}.t-title{font-weight:700;font-size:.88em;color:var(--acc);}.t-txt{font-size:.82em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;}

/* LOGIN */
#login{position:fixed;inset:0;z-index:300;background:var(--grad);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:30px;}
.l-title{font-size:2em;font-family:'Poppins',sans-serif;font-weight:700;margin-bottom:40px;text-shadow:0 4px 10px rgba(0,0,0,.5);}
.profiles{display:flex;gap:24px;width:100%;max-width:340px;}
.pcard{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:24px 16px;cursor:pointer;flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;transition:.2s;}
.pcard:active{transform:scale(.94);}
.pcard .emo{font-size:3.2em;}

/* PASSWORD MODAL */
#pwd-modal{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:800;display:none;align-items:center;justify-content:center;padding:20px;}
.pwd-box{background:#1c1c1e;border-radius:20px;padding:28px 22px;width:100%;max-width:320px;text-align:center;}
.pwd-box h3{margin-bottom:18px;font-size:1.1em;}
.pwd-box input{width:100%;padding:13px;border-radius:11px;border:1px solid #444;background:#2a2a2c;color:white;outline:none;margin-bottom:16px;font-size:1.1em;text-align:center;letter-spacing:4px;}
.pwd-row{display:flex;gap:10px;}
.pwd-row button{flex:1;padding:13px;border-radius:11px;border:none;font-weight:700;cursor:pointer;font-size:.95em;}
.pwd-cancel{background:#3a3a3c;color:white;}
.pwd-ok{background:var(--acc);color:white;}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-5px)}80%{transform:translateX(5px)}}

/* CAMERA MODAL */
#cam-modal{position:fixed;inset:0;background:#000;z-index:700;display:none;flex-direction:column;align-items:center;justify-content:center;}
#cam-video{width:100%;max-height:75vh;object-fit:cover;}
.cam-bar{display:flex;gap:20px;padding:20px;align-items:center;justify-content:center;}
.cam-btn{width:60px;height:60px;border-radius:50%;border:none;cursor:pointer;font-size:1.4em;display:flex;align-items:center;justify-content:center;}
.cam-shutter{background:white;width:68px;height:68px;}
.cam-flip{background:rgba(255,255,255,.2);color:white;}
.cam-close{background:rgba(255,59,48,.8);color:white;}
.cam-once-toggle{background:rgba(255,255,255,.15);color:white;font-size:.7em;padding:8px 16px;border-radius:20px;border:none;cursor:pointer;font-weight:700;}
.cam-once-toggle.on{background:var(--acc);}
#cam-canvas{display:none;}

/* VIDEO CALL */
#call-modal{position:fixed;inset:0;background:#0a0a0a;z-index:600;display:none;flex-direction:column;}
.call-videos{flex:1;position:relative;background:#111;}
#remote-video{width:100%;height:100%;object-fit:cover;background:#1a1a1a;}
#local-video{position:absolute;bottom:16px;right:16px;width:110px;height:150px;object-fit:cover;border-radius:12px;border:2px solid var(--acc);background:#222;}
.call-status{position:absolute;top:16px;left:0;right:0;text-align:center;font-size:.9em;color:rgba(255,255,255,.8);font-weight:600;text-shadow:0 1px 4px #000;}
.call-bar{display:flex;gap:20px;padding:20px 20px 36px;background:#111;justify-content:center;align-items:center;}
.call-action{width:58px;height:58px;border-radius:50%;border:none;cursor:pointer;font-size:1.3em;display:flex;align-items:center;justify-content:center;}
.call-end{background:#ff3b30;color:white;width:66px;height:66px;}
.call-mute{background:#3a3a3c;color:white;}
.call-cam-toggle{background:#3a3a3c;color:white;}

/* INCOMING CALL */
#incoming-call{position:fixed;bottom:-200px;left:5%;width:90%;background:#202329;border-radius:20px;padding:20px;z-index:850;transition:bottom .4s cubic-bezier(.175,.885,.32,1.275);box-shadow:0 -8px 30px rgba(0,0,0,.6);border-top:3px solid var(--acc);text-align:center;}
#incoming-call.show{bottom:100px;}
#incoming-call h3{margin-bottom:6px;font-size:1em;}
#incoming-call p{color:var(--sub);font-size:.85em;margin-bottom:16px;}
.inc-btns{display:flex;gap:16px;justify-content:center;}
.inc-answer{background:#34c759;color:white;padding:14px 28px;border:none;border-radius:50px;font-weight:700;cursor:pointer;font-size:1em;}
.inc-reject{background:#ff3b30;color:white;padding:14px 28px;border:none;border-radius:50px;font-weight:700;cursor:pointer;font-size:1em;}

/* APP */
.app{display:flex;flex-direction:column;height:100vh;width:100%;max-width:600px;margin:0 auto;}
.header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:rgba(15,15,20,.85);backdrop-filter:blur(10px);z-index:10;border-bottom:1px solid rgba(255,255,255,.05);}
.badge{font-weight:700;font-size:1.05em;display:flex;align-items:center;gap:8px;}
.hbtns{display:flex;gap:12px;}
.hbtn{background:none;border:none;color:white;font-size:1.25em;cursor:pointer;}
.hbtn:active{transform:scale(.8);}

.tab{display:none;flex:1;flex-direction:column;overflow:hidden;}
.tab.on{display:flex;animation:fi .25s;}
@keyframes fi{from{opacity:0}to{opacity:1}}

/* CHAT */
.chat-topbar{display:flex;gap:8px;padding:9px 14px;background:rgba(0,0,0,.4);border-bottom:1px solid rgba(255,255,255,.05);}
.cgame{flex:1;padding:8px;border-radius:10px;border:none;font-weight:700;font-size:.82em;color:white;cursor:pointer;}
.chatbox{flex:1;padding:14px 11px;display:flex;flex-direction:column;gap:11px;overflow-y:auto;padding-bottom:18px;}
.mwrap{display:flex;flex-direction:column;max-width:76%;}
.wmine{align-self:flex-end;}.wother{align-self:flex-start;}.wsys{align-self:center;max-width:92%;margin:8px 0;}
.msg{padding:8px 12px 22px 12px;border-radius:16px;font-size:.93em;position:relative;}
.mmine{background:var(--mine);border-top-right-radius:4px;}
.mother{background:var(--other);border-top-left-radius:4px;}
.msys{background:rgba(0,0,0,.5);color:#f1c40f;text-align:center;border-radius:12px;font-size:.82em;padding:8px 14px;}
.mauthor{font-weight:700;color:var(--acc);font-size:.78em;margin-bottom:3px;}
.mcontent{word-break:break-word;line-height:1.45;}
.mmeta{position:absolute;bottom:4px;right:8px;display:flex;align-items:center;gap:3px;font-size:.67em;color:var(--tc);}
.sread{color:#53bdeb;}

/* PHOTO once */
.once-wrap{position:relative;display:inline-block;cursor:pointer;}
.once-wrap img{max-width:180px;border-radius:10px;display:block;}
.once-badge{position:absolute;top:6px;right:6px;background:rgba(0,0,0,.7);border-radius:20px;padding:3px 9px;font-size:.7em;color:#fff;}
.once-expired{background:rgba(255,255,255,.07);border-radius:10px;padding:18px 26px;font-size:.83em;color:var(--sub);text-align:center;}

/* VOICE */
.vbubble{display:flex;align-items:center;gap:10px;padding:4px 0;min-width:190px;}
.vplay{width:36px;height:36px;border-radius:50%;background:var(--acc);border:none;color:white;font-size:.95em;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.vwave{flex:1;height:28px;overflow:hidden;}
.vbars{display:flex;align-items:center;gap:2px;height:100%;}
.vbar{flex:1;background:rgba(255,255,255,.3);border-radius:2px;}
.vbar.p{background:rgba(255,255,255,.85);}
.vdur{font-size:.7em;color:var(--tc);min-width:32px;}

/* INPUT */
.input-area{padding:7px 10px 10px;background:rgba(10,10,15,.7);backdrop-filter:blur(10px);border-top:1px solid rgba(255,255,255,.06);}
.irow{display:flex;align-items:flex-end;gap:7px;}
.ibox-wrap{flex:1;background:#2a2a2c;border-radius:22px;display:flex;align-items:center;padding:4px 10px;min-height:44px;}
.ibox{flex:1;background:none;border:none;padding:8px 4px;color:white;outline:none;font-size:.93em;resize:none;max-height:90px;}
.ibtn{background:none;border:none;color:var(--sub);font-size:1.35em;cursor:pointer;padding:4px;flex-shrink:0;}
.sndbtn{width:44px;height:44px;border-radius:50%;background:var(--acc);border:none;color:white;font-size:1.05em;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.recbtn{width:44px;height:44px;border-radius:50%;background:#3a3a3c;border:none;color:white;font-size:1.1em;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.recbtn.rec{background:#ff3b30;animation:prec 1s infinite;}
@keyframes prec{0%,100%{box-shadow:0 0 0 0 rgba(255,59,48,.5)}50%{box-shadow:0 0 0 8px rgba(255,59,48,0)}}
.rectimer{font-size:.72em;color:#ff3b30;text-align:center;padding-top:2px;display:none;}

/* NAV */
.nav{display:flex;padding:10px 4px 22px;background:#16161a;border-top:1px solid #222;}
.ni{flex:1;color:var(--sub);font-size:1.2em;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;}
.ni span{font-size:.33em;text-transform:uppercase;letter-spacing:.5px;}
.ni.on{color:var(--acc);}

/* TABS INNER */
.tinner{padding:18px;overflow-y:auto;flex:1;}
.cpanel{background:rgba(0,0,0,.4);border-radius:16px;padding:18px;text-align:center;margin-bottom:14px;}
.sbtn{background:var(--acc);padding:13px;border:none;border-radius:12px;width:100%;font-weight:700;color:#fff;cursor:pointer;margin-bottom:9px;font-size:.93em;}
.sbtn.red{background:#ff3b30;}.sbtn.ghost{background:rgba(255,255,255,.1);color:white;}
input[type=number],input[type=text].si,textarea{width:100%;padding:11px;border-radius:11px;border:1px solid #333;margin-bottom:9px;background:#1c1c1e;color:white;outline:none;font-size:.93em;}

/* DROIT */
.dq-display{background:rgba(255,255,255,.06);border-radius:13px;padding:16px;margin:13px 0;font-size:1em;font-style:italic;min-height:65px;display:flex;align-items:center;justify-content:center;color:var(--fg);line-height:1.5;text-align:center;}
.dbtns{display:flex;gap:11px;}
.doui{background:linear-gradient(135deg,#00b894,#00a884);}.dnon{background:linear-gradient(135deg,#ff3b30,#c0392b);}

/* PET */
#pet-wrap{width:100%;height:280px;border-radius:22px;overflow:hidden;background:linear-gradient(180deg,#1c1024,#2e1835);position:relative;margin-bottom:14px;display:flex;justify-content:center;align-items:center;}
#pet3d{width:100%;height:100%;position:absolute;top:0;left:0;z-index:2;}
#dilan-fb{font-size:5.5em;z-index:1;animation:flt 3s ease-in-out infinite;}
@keyframes flt{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.tbar{display:flex;justify-content:space-around;padding:8px;margin-bottom:18px;}
.tg{width:62px;height:62px;border-radius:50%;background:conic-gradient(var(--acc) var(--p),rgba(255,255,255,.1) 0);display:flex;justify-content:center;align-items:center;position:relative;cursor:pointer;transition:transform .2s;}
.tg:active{transform:scale(.9);}
.tgi{width:52px;height:52px;background:#202329;border-radius:50%;display:flex;justify-content:center;align-items:center;font-size:1.4em;border:2px solid #111;}
.tgl{position:absolute;bottom:-19px;font-size:.62em;font-weight:700;color:white;background:rgba(0,0,0,.55);padding:2px 6px;border-radius:9px;}

/* SCORES */
.stab{width:100%;text-align:center;margin-bottom:14px;border-collapse:collapse;}
.stab th{color:var(--acc);font-size:.88em;padding-bottom:5px;}
.stab td{font-size:1.5em;font-weight:700;}

/* ADMIN */
.asec{background:rgba(0,0,0,.4);border-radius:15px;padding:15px;margin-bottom:13px;}
.asec h3{color:var(--acc);margin-bottom:11px;font-size:.85em;text-transform:uppercase;letter-spacing:1px;}
.arow{display:flex;gap:9px;align-items:center;margin-bottom:9px;}
.arow input{flex:1;padding:10px;border-radius:10px;border:1px solid #333;background:#1c1c1e;color:white;outline:none;font-size:.9em;}
.asmall{background:var(--acc);padding:10px 14px;border:none;border-radius:10px;color:white;font-weight:700;cursor:pointer;font-size:.9em;white-space:nowrap;}

/* SECRET */
.sitem{background:rgba(0,0,0,.3);padding:11px;border-radius:10px;margin-bottom:7px;border-left:3px solid var(--acc);text-align:left;}
.sauth{font-size:.7em;color:var(--acc);margin-bottom:3px;}
</style>
</head>
<body>

<!-- TOAST -->
<div id="toast" onclick="goChat()">
  <div class="t-ico">💬</div>
  <div><div class="t-title" id="t-title">Nouveau message</div><div class="t-txt" id="t-txt">...</div></div>
</div>

<!-- INCOMING CALL -->
<div id="incoming-call">
  <h3>📞 Appel entrant</h3>
  <p id="inc-caller">...</p>
  <div class="inc-btns">
    <button class="inc-reject" onclick="rejectCall()">❌ Refuser</button>
    <button class="inc-answer" onclick="answerCall()">✅ Répondre</button>
  </div>
</div>

<!-- PASSWORD MODAL -->
<div id="pwd-modal">
  <div class="pwd-box">
    <h3 id="pwd-title">🔐 Mot de passe</h3>
    <input type="password" id="pwd-input" placeholder="••••" maxlength="20" onkeydown="if(event.key==='Enter')pwdOk()">
    <div class="pwd-row">
      <button class="pwd-cancel" onclick="pwdClose()">Annuler</button>
      <button class="pwd-ok" onclick="pwdOk()">Entrer</button>
    </div>
  </div>
</div>

<!-- CAMERA MODAL -->
<div id="cam-modal">
  <video id="cam-video" autoplay playsinline muted></video>
  <canvas id="cam-canvas"></canvas>
  <div class="cam-bar">
    <button class="cam-btn cam-close" onclick="closeCamera()">✕</button>
    <button class="cam-btn cam-shutter" onclick="takePhoto()">📸</button>
    <button class="cam-btn cam-flip" onclick="flipCamera()">🔄</button>
  </div>
  <div style="display:flex;justify-content:center;padding-bottom:16px;">
    <button class="cam-once-toggle" id="once-toggle" onclick="toggleOnce()">👁 Vue unique : OFF</button>
  </div>
</div>

<!-- VIDEO CALL MODAL -->
<div id="call-modal">
  <div class="call-videos">
    <video id="remote-video" autoplay playsinline></video>
    <video id="local-video" autoplay playsinline muted></video>
    <div class="call-status" id="call-status">Connexion...</div>
  </div>
  <div class="call-bar">
    <button class="call-action call-mute" id="mute-btn" onclick="toggleMute()">🎤</button>
    <button class="call-action call-end" onclick="endCall()">📵</button>
    <button class="call-action call-cam-toggle" id="cam-toggle-btn" onclick="toggleCallCam()">📷</button>
  </div>
</div>

<!-- LOGIN -->
<div id="login">
  <div class="l-title">Notre Espace ❤️</div>
  <div class="profiles">
    <div class="pcard" onclick="openPwd('Imane')">
      <div class="emo">👩🏽</div><div>Imane</div>
    </div>
    <div class="pcard" onclick="openPwd('Elhadj')">
      <div class="emo">🧔‍♂️</div><div>El-hadj</div>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app" id="app" style="display:none;">
  <div class="header">
    <div class="badge" id="badge"></div>
    <div class="hbtns">
      <button class="hbtn" id="btn-call" onclick="startCall()" style="display:none;" title="Appel vidéo">📹</button>
      <button class="hbtn" id="btn-switch" onclick="switchAcc()" style="display:none;">🔄</button>
      <button class="hbtn" onclick="toggleTheme()">🎨</button>
      <button class="hbtn" onclick="logout()">🚪</button>
    </div>
  </div>

  <!-- CHAT -->
  <div id="tab-chat" class="tab on">
    <div class="chat-topbar">
      <button class="cgame" style="background:#ff9a44;" onclick="distDefi('action')">🎯 Action</button>
      <button class="cgame" style="background:#4facfe;" onclick="distDefi('verite')">🎯 Vérité</button>
    </div>
    <div class="chatbox" id="chatbox"></div>
    <div class="input-area">
      <div class="irow">
        <button class="ibtn" style="color:white;font-size:1.5em;" onclick="openCamera()">📷</button>
        <div class="ibox-wrap">
          <textarea class="ibox" id="msginput" placeholder="Message..." rows="1"
            onkeydown="msgKey(event)" oninput="msgResize(this)"></textarea>
        </div>
        <button class="recbtn" id="recbtn" onmousedown="recStart(event)" ontouchstart="recStart(event)" onmouseup="recStop(event)" ontouchend="recStop(event)">🎤</button>
        <button class="sndbtn" id="sndbtn" onclick="sendMsg()" style="display:none;">➤</button>
      </div>
      <div class="rectimer" id="rectimer">⏺ <span id="recsec">0</span>s — relâche pour envoyer</div>
    </div>
  </div>

  <!-- DROIT -->
  <div id="tab-droit" class="tab">
    <div class="tinner">
      <h1 style="margin-bottom:18px;">J'ai le droit ou pas ? 🥺</h1>
      <div id="droit-imane">
        <div class="cpanel" style="min-height:180px;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:14px;">
          <p style="color:var(--sub);font-size:.88em;">Génère une question pour El-hadj !</p>
          <button class="sbtn" style="background:linear-gradient(45deg,#833ab4,#fd1d1d,#fcb045);padding:17px;font-size:1.05em;border-radius:18px;" onclick="imaneAsk()">🙋🏽‍♀️ Générer une question</button>
          <p id="droit-fb" style="color:var(--acc);font-weight:700;display:none;">✅ Envoyée dans le chat !</p>
        </div>
      </div>
      <div id="droit-elhadj" style="display:none;">
        <div class="cpanel">
          <p style="color:var(--sub);font-size:.85em;margin-bottom:11px;">Génère ta propre question pour Imane</p>
          <button class="sbtn" style="background:linear-gradient(45deg,#0f3460,#533483,#e94560);" onclick="elhadjAsk()">🧔‍♂️ Ma question</button>
        </div>
        <div class="cpanel">
          <p style="color:var(--acc);font-weight:700;margin-bottom:8px;">📩 Question en attente :</p>
          <div class="dq-display" id="droit-q">Aucune question...</div>
          <div class="dbtns" id="droit-ans" style="display:none;">
            <button class="sbtn dnon" onclick="answerDroit('Non ❌')">❌ Non</button>
            <button class="sbtn doui" onclick="answerDroit('Oui ✅')">✅ Oui</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- JEUX -->
  <div id="tab-jeux" class="tab">
    <div class="tinner">
      <h1 style="margin-bottom:15px;">Face à Face</h1>
      <div style="display:flex;gap:9px;margin-bottom:18px;">
        <button class="sbtn" style="background:#ff9a44;" onclick="localDefi('action')">ACTION</button>
        <button class="sbtn" style="background:#4facfe;" onclick="localDefi('verite')">VÉRITÉ</button>
      </div>
      <div class="cpanel" style="min-height:140px;display:flex;flex-direction:column;justify-content:center;gap:10px;">
        <div id="ltag" style="color:#fd3c56;font-size:.88em;font-weight:700;">PRÊTS ?</div>
        <div id="ltxt" style="font-size:1.02em;font-weight:700;line-height:1.5;">Appuie pour lancer...</div>
      </div>
    </div>
  </div>

  <!-- DILAN -->
  <div id="tab-dilan" class="tab">
    <div class="tinner" style="padding-top:10px;">
      <h1 style="margin-bottom:10px;">Bébé Dilan</h1>
      <div id="pet-wrap"><div id="dilan-fb">🐻</div><canvas id="pet3d"></canvas></div>
      <div class="tbar">
        <div class="tg" id="g-faim" style="--p:50%;--acc:#ff9f43;" onclick="feedDilan('faim')"><div class="tgi">🍔</div><div class="tgl" id="l-faim">50%</div></div>
