// ========== VOICE MESSAGES ==========
function buildVoice(m){
  const bars=Array.from({length:20},(_,i)=>{
    const h=Math.max(5,18+Math.sin(i*.9+(parseInt(m.id)%8))* 12);
    return `<div class="vbar" style="height:${h}px"></div>`;
  }).join('');
  const dur = m.voiceDuration?fmtDur(m.voiceDuration):'0:00';
  return `<div class="vbubble" onclick="playVoice('${m.id}')">
    <button class="vplay" id="vp-${m.id}">▶️</button>
    <div class="vwave"><div class="vbars" id="vb-${m.id}">${bars}</div></div>
    <span class="vdur" id="vd-${m.id}">${dur}</span>
  </div>`;
}
const audioPlaying={};
function playVoice(id){
  const m=S.messages.find(x=>x.id===id);
  if(!m||!m.voice)return;
  if(audioPlaying[id]){ audioPlaying[id].pause(); delete audioPlaying[id]; return; }
  const a=new Audio(m.voice); audioPlaying[id]=a;
  const btn=document.getElementById('vp-'+id);
  const dur=m.voiceDuration||1;
  const start=Date.now();
  if(btn) btn.textContent='⏸';
  const iv=setInterval(()=>{
    const prog=Math.min((Date.now()-start)/1000/dur,1);
    const bars=document.querySelectorAll('#vb-'+id+' .vbar');
    bars.forEach((b,i)=>b.classList.toggle('p',i/bars.length<prog));
    const dEl=document.getElementById('vd-'+id);
    if(dEl) dEl.textContent=fmtDur(Math.max(0,dur-(Date.now()-start)/1000));
  },80);
  a.onended=()=>{ clearInterval(iv); if(btn) btn.textContent='▶️'; delete audioPlaying[id]; document.querySelectorAll('#vb-'+id+' .vbar').forEach(b=>b.classList.remove('p')); };
  a.onerror=()=>{ clearInterval(iv); if(btn) btn.textContent='▶️'; delete audioPlaying[id]; };
  a.play().catch(()=>{});
}

