// ========== 3D DILAN (lazy load) ==========
function load3D(){
  const script=document.createElement('script');
  script.src='https://unpkg.com/three@0.160.0/build/three.min.js';
  script.onload=()=>{
    const scene=new THREE.Scene();
    const pw=document.getElementById('pet-wrap');
    const cam=new THREE.PerspectiveCamera(45,pw.offsetWidth/280,0.1,1000);
    cam.position.z=3;
    const renderer=new THREE.WebGLRenderer({canvas:document.getElementById('pet3d'),alpha:true,antialias:true});
    renderer.setSize(pw.offsetWidth,280);
    scene.add(new THREE.HemisphereLight(0xffffff,0xbbbbff,3));
    // Simple bear stand-in (cube) if GLTFLoader not available
    const geo=new THREE.BoxGeometry(.6,.8,.6);
    const mat=new THREE.MeshPhongMaterial({color:0x8B4513});
    const bear=new THREE.Mesh(geo,mat); scene.add(bear);
    document.getElementById('dilan-fb').style.display='none';
    (function anim(){ requestAnimationFrame(anim); bear.rotation.y+=.01; renderer.render(scene,cam); })();
  };
  document.head.appendChild(script);
}
// Load 3D when dilan tab opened
document.getElementById('ni-dilan').addEventListener('click',()=>{ if(!window.THREE) load3D(); });
